{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://example.com/schemas/question_labeling.json",
 "type": "object",
 "additionalProperties": false,
 "properties": {
   "content_categories": {
     "type": "array",
     "minItems": 0,
     "maxItems": 12,
     "items": { "type": "string", "minLength": 1, "maxLength": 40 }
   },
   "topics": {
     "type": "array",
     "minItems": 0,
     "maxItems": 20,
     "items": { "type": "string", "minLength": 1, "maxLength": 40 }
   },
   "audience_fit": {
     "type": "array",
     "minItems": 0,
     "maxItems": 6,
     "items": { "type": "string", "enum": ["friends", "coworkers", "family", "couples", "strangers", "mixed"] }
   },
   "depth_level": { "type": "integer", "minimum": 1, "maximum": 5 },
   "family_friendly_ok": { "type": "boolean" }
 },
 "required": ["content_categories", "topics", "audience_fit", "depth_level", "family_friendly_ok"]
}
