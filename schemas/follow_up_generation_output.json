{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://example.com/schemas/followup_generation.json",
 "type": "object",
 "additionalProperties": false,
 "properties": {
   "prompts": {
     "type": "array",
     "minItems": 1,
     "maxItems": 8,
     "items": {
       "type": "object",
       "additionalProperties": false,
       "properties": {
         "prompt_text": { "type": "string", "minLength": 1, "maxLength": 180 },
         "options": {
           "type": "array",
           "minItems": 4,
           "maxItems": 8,
           "items": { "type": "string", "minLength": 1, "maxLength": 60 }
         },
         "allow_other": { "type": "boolean" },
         "answer_type": { "type": "string", "enum": ["single_select"] }
       },
       "required": ["prompt_text", "options", "allow_other", "answer_type"]
     }
   }
 },
 "required": ["prompts"]
}
